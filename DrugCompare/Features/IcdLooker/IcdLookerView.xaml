<UserControl
    x:Class="DrugCompare.Features.IcdLooker.IcdLookerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="760"
    d:DesignWidth="1180">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#EEF2FF"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="88*"/>
            <RowDefinition Height="37*"/>
            <RowDefinition Height="Auto" MinHeight="0"/>
        </Grid.RowDefinitions>

        <!-- Wyszukiwanie -->
        <Border Grid.Row="0"
                Background="White"
                Margin="5,5,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Text="Wyszukiwarka kodów ICD-11"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Margin="10,10,0,6" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Wyszukaj po fragmencie kodu, kodzie rodzica, nazwie lub opisie"
                    FontWeight="SemiBold"
                    Margin="10,0,0,0" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Dział"
                    FontWeight="SemiBold"
                    Margin="14,0,0,6" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Wyszukaj po fragmencie kodu, kodzie rodzica, nazwie lub opisie" 
                    Margin="180,5,0,5"/>

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="Wyszukaj:"
                    FontWeight="SemiBold"
                     Margin="90,16,0,6"
                    FontSize="18"/>

                <ComboBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="14,5,28,5"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Filtruj według działu ICD" />

                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    Content="Szukaj"
                    Command="{Binding SearchCommand}"
                    Margin="0,12,10,12" />

                <Button
                    Grid.Row="2"
                    Grid.Column="3"
                    Content="Wyczyść"
                    Command="{Binding ClearCommand}"
                    Margin="0,12,10,12" />
            </Grid>
        </Border>

        <!-- Wyniki -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="5,5,5,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock
                        Text="Wyniki"
                        FontSize="18"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Left" />

                    <TextBlock
                        Text="{Binding StatusMessage}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right" />
                </DockPanel>

                <DataGrid
                    Grid.Row="1"
                    ItemsSource="{Binding Results}"
                    SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                    EnableRowVirtualization="True"
                    EnableColumnVirtualization="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Kod"
                            Binding="{Binding Code}"
                            Width="110" />

                        <DataGridTextColumn
                            Header="Kod rodzica"
                            Binding="{Binding ParentCode}"
                            Width="130" />

                        <DataGridTextColumn
                            Header="Nazwa"
                            Binding="{Binding Title}"
                            Width="*" />
                        <DataGridTextColumn
                            Header="Dział"
                            Binding="{Binding Chapter}"
                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Szczegóły -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}"  Margin="5,5,5,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="142"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{StaticResource SoftAccentBrush}"
                    BorderBrush="#C7D2FE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,14,0">

                    <StackPanel>
                        <TextBlock
                            Text="Kod"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SecondaryTextBrush}" />

                        <TextBlock
                            Text="{Binding SelectedResult.Code, TargetNullValue=—}"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="0,8,0,12" />
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Pełny opis"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,0,0,10" />

                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <TextBlock
                            Text="{Binding SelectedResult.Description}"
                            TextWrapping="Wrap"
                            FontSize="15"
                            LineHeight="23"
                            Foreground="{StaticResource PrimaryTextBrush}" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Pasek statusu -->


    </Grid>
</UserControl>