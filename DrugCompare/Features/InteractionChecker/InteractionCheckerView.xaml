<UserControl
    x:Class="DrugCompare.Features.InteractionChecker.InteractionCheckerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:DrugCompare.Presentation.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="White">

    <UserControl.Resources>
        <converters:SeverityToBrushConverter x:Key="SeverityToBrushConverter"/>

        <!-- Kolory bazowe -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF7E6"/>
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#F2C879"/>
        <SolidColorBrush x:Key="WarningTextBrush" Color="#8A5A00"/>

        <!-- Kolory ryzyka -->
        <SolidColorBrush x:Key="SeverityCriticalBrush" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="SeverityCriticalBorderBrush" Color="#EF4444"/>

        <SolidColorBrush x:Key="SeverityHighBrush" Color="#FFEDD5"/>
        <SolidColorBrush x:Key="SeverityHighBorderBrush" Color="#F97316"/>

        <SolidColorBrush x:Key="SeverityMediumBrush" Color="#FEF9C3"/>
        <SolidColorBrush x:Key="SeverityMediumBorderBrush" Color="#EAB308"/>

        <SolidColorBrush x:Key="SeverityLowBrush" Color="#DCFCE7"/>
        <SolidColorBrush x:Key="SeverityLowBorderBrush" Color="#22C55E"/>

        <SolidColorBrush x:Key="SeverityUnknownBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SeverityUnknownBorderBrush" Color="#9CA3AF"/>

        <!-- Karta -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="InnerInfoBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftAccentBrush}"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- Teksty -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Button -->
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="36"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- Kolorowanie wierszy interakcji -->
        <Style x:Key="InteractionResultRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                    <Setter Property="Background" Value="{StaticResource SeverityCriticalBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityCriticalBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Contraindicated">
                    <Setter Property="Background" Value="{StaticResource SeverityCriticalBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityCriticalBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="X">
                    <Setter Property="Background" Value="{StaticResource SeverityCriticalBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityCriticalBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="High">
                    <Setter Property="Background" Value="{StaticResource SeverityHighBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityHighBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Major">
                    <Setter Property="Background" Value="{StaticResource SeverityHighBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityHighBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="D">
                    <Setter Property="Background" Value="{StaticResource SeverityHighBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityHighBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                    <Setter Property="Background" Value="{StaticResource SeverityMediumBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityMediumBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Moderate">
                    <Setter Property="Background" Value="{StaticResource SeverityMediumBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityMediumBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="C">
                    <Setter Property="Background" Value="{StaticResource SeverityMediumBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityMediumBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Low">
                    <Setter Property="Background" Value="{StaticResource SeverityLowBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityLowBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Minor">
                    <Setter Property="Background" Value="{StaticResource SeverityLowBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityLowBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="B">
                    <Setter Property="Background" Value="{StaticResource SeverityLowBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityLowBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="Unknown">
                    <Setter Property="Background" Value="{StaticResource SeverityUnknownBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityUnknownBorderBrush}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Severity}" Value="A">
                    <Setter Property="Background" Value="{StaticResource SeverityUnknownBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SeverityUnknownBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="390"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEWY PANEL -->
        <Border
            Grid.Column="0"
            Style="{StaticResource CardBorderStyle}"
            Margin="5,0,8,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="1. Wyszukiwanie leku"
                    Style="{StaticResource SectionTitleStyle}"/>

                <StackPanel Grid.Row="1">
                    <TextBlock
                        Text="Nazwa leku"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox
                        Text="{Binding DrugNameInput, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Wpisz nazwę leku, aby wykryć substancje czynne"/>

                    <Button
                        Content="Znajdź lek"
                        Command="{Binding FindDrugCommand}"
                        Style="{StaticResource BaseButtonStyle}"
                        Margin="0,0,0,12"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock
                            Text="Wykryte substancje czynne"
                            Style="{StaticResource LabelStyle}"
                            DockPanel.Dock="Left"/>

                        <TextBlock
                            Text="{Binding DetectedSubstances.Count, StringFormat=Liczba: {0}}"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="11"
                            HorizontalAlignment="Right"/>
                    </DockPanel>

                    <ListBox
                        Grid.Row="1"
                        ItemsSource="{Binding DetectedSubstances}"
                        SelectedItem="{Binding SelectedDetectedSubstance}"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        HorizontalContentAlignment="Stretch">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="#F8FAFC"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">

                                    <StackPanel>
                                        <TextBlock
                                            Text="{Binding Name}"
                                            FontWeight="Bold"
                                            FontSize="13"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            TextWrapping="Wrap"/>

                                        <TextBlock
                                            Text="{Binding DatabaseId, StringFormat=DB ID: {0}}"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            FontSize="11"
                                            Margin="0,4,0,0"/>

                                        <TextBlock
                                            Text="{Binding DDInterId, StringFormat=DDInter: {0}}"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            FontSize="11"/>

                                        <TextBlock
                                            Text="{Binding Source}"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            FontSize="11"
                                            TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Row="3" Margin="0,12,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="Akceptuj wybraną"
                        Command="{Binding AcceptDetectedSubstanceCommand}"
                        Style="{StaticResource BaseButtonStyle}"/>

                    <Button
                        Grid.Column="2"
                        Content="Akceptuj wszystkie"
                        Command="{Binding AcceptAllDetectedSubstancesCommand}"
                        Style="{StaticResource BaseButtonStyle}"/>
                </Grid>

                <Separator Grid.Row="4" Margin="0,0,0,14"/>

                <StackPanel Grid.Row="5">
                    <TextBlock
                        Text="2. Ręczne dodanie substancji"
                        Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock
                        Text="Nazwa substancji czynnej"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox
                        Text="{Binding ManualSubstanceInput, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Wpisz dokładną nazwę substancji czynnej"/>

                    <Button
                        Content="Dodaj substancję czynną"
                        Command="{Binding AddManualSubstanceCommand}"
                        Style="{StaticResource BaseButtonStyle}"/>

                    <Border
                        Style="{StaticResource InnerInfoBorderStyle}"
                        Margin="0,10,0,0">

                        <TextBlock
                            Text="Wskazówka: dla testów DDInter najlepiej wkleić dokładną nazwę substancji czynnej z bazy."
                            Style="{StaticResource MutedTextStyle}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ŚRODKOWY PANEL -->
        <Border
            Grid.Column="1"
            Style="{StaticResource CardBorderStyle}"
            Margin="8,0,8,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock
                        Text="3. Substancje do sprawdzenia"
                        Style="{StaticResource SectionTitleStyle}"
                        DockPanel.Dock="Left"/>

                    <TextBlock
                        Text="{Binding AcceptedSubstances.Count, StringFormat=Liczba: {0}}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="11"
                        HorizontalAlignment="Right"/>
                </DockPanel>

                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding AcceptedSubstances}"
                    SelectedItem="{Binding SelectedAcceptedSubstance}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    HorizontalContentAlignment="Stretch">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="12"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Background="White">

                                <StackPanel>
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        TextWrapping="Wrap"/>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="DB ID:"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            FontSize="11"
                                            Margin="0,0,6,0"/>

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding DatabaseId}"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            FontSize="11"/>
                                    </Grid>

                                    <TextBlock
                                        Text="{Binding DDInterId, StringFormat=DDInter: {0}}"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        FontSize="11"/>

                                    <TextBlock
                                        Text="{Binding Source}"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        FontSize="11"
                                        TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <Button
                        Content="Sprawdź interakcje"
                        Command="{Binding CheckInteractionsCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,8"/>

                    <Button
                        Content="Usuń wybraną substancję"
                        Command="{Binding RemoveAcceptedSubstanceCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="0,0,0,8"/>

                    <Button
                        Content="Eksportuj bieżący raport"
                        Command="{Binding ExportCurrentReportCommand}"
                        Style="{StaticResource BaseButtonStyle}"
                        Margin="0,0,0,8"/>

                    <Button
                        Content="Wyczyść przypadek"
                        Command="{Binding ClearCaseCommand}"
                        Style="{StaticResource BaseButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PRAWY PANEL -->
        <Border
            Grid.Column="2"
            Style="{StaticResource CardBorderStyle}"
            Margin="8,0,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="330"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock
                        Text="4. Wyniki interakcji"
                        Style="{StaticResource SectionTitleStyle}"
                        DockPanel.Dock="Left"/>

                    <TextBlock
                        Text="{Binding InteractionResults.Count, StringFormat=Liczba: {0}}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="11"
                        HorizontalAlignment="Right"/>
                </DockPanel>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource WarningBackgroundBrush}"
                    BorderBrush="{StaticResource WarningBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10">

                    <TextBlock
                        Text="{Binding ResultSummaryMessage}"
                        FontSize="12"
                        Foreground="{StaticResource WarningTextBrush}"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap"/>
                </Border>

                <DataGrid
                    Grid.Row="2"
                    ItemsSource="{Binding InteractionResults}"
                    SelectedItem="{Binding SelectedInteraction}"
                    RowStyle="{StaticResource InteractionResultRowStyle}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    Margin="0,0,0,12">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Substancja A"
                            Binding="{Binding SubstanceA}"
                            Width="150"/>

                        <DataGridTextColumn
                            Header="Substancja B"
                            Binding="{Binding SubstanceB}"
                            Width="150"/>

                        <DataGridTextColumn
                            Header="Ryzyko"
                            Binding="{Binding Severity}"
                            Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Header="Komunikat"
                            Binding="{Binding Message}"
                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn
                            Header="Źródło"
                            Binding="{Binding Source}"
                            Width="190">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock
                    Grid.Row="3"
                    Text="Szczegóły wybranej interakcji"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    Margin="0,0,0,8"/>

                <Border
                    Grid.Row="4"
                    Background="#F8FAFC"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock
                                Text="Ryzyko"
                                Style="{StaticResource LabelStyle}"/>

                            <TextBlock
                                Text="{Binding SelectedInteraction.Severity, TargetNullValue=—}"
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="{Binding SelectedInteraction.Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                TextWrapping="Wrap"
                                Margin="0,0,0,10"/>

                            <TextBlock
                                Text="Komunikat"
                                Style="{StaticResource LabelStyle}"/>

                            <TextBlock
                                Text="{Binding SelectedInteraction.Message}"
                                FontSize="12"
                                TextWrapping="Wrap"
                                LineHeight="20"
                                Margin="0,0,0,10"/>

                            <TextBlock
                                Text="Źródło"
                                Style="{StaticResource LabelStyle}"/>

                            <TextBlock
                                Text="{Binding SelectedInteraction.Source, TargetNullValue=Lokalna baza interakcji}"
                                FontSize="12"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap"
                                Margin="0,0,0,12"/>

                            <Border
                                Background="{StaticResource SoftAccentBrush}"
                                BorderBrush="#C7D2FE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,8,0,0">

                                <TextBlock
                                    Text="Brak znalezionej interakcji w lokalnej bazie nie oznacza, że połączenie jest bezpieczne. Wynik wymaga interpretacji klinicznej."
                                    FontSize="12"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>