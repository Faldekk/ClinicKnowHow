<UserControl x:Class="DrugCompare.Features.DrugExplorer.DrugExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Drug Explorer"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Search local drug records and linked active substances."
                           Margin="0,4,0,0"
                           Opacity="0.75"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBox Width="320"
                         Height="34"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding DrugExplorerQuery, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Search"
                        Width="110"
                        Height="34"
                        Command="{Binding SearchDrugExplorerCommand}"/>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DrugExplorerResults}"
                  SelectedItem="{Binding SelectedDrugExplorerResult, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Drug"
                                    Binding="{Binding DrugName}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Manufacturer"
                                    Binding="{Binding Manufacturer}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Substances"
                                    Binding="{Binding ActiveSubstances}"
                                    Width="3*"/>

                <DataGridTextColumn Header="Source"
                                    Binding="{Binding Source}"
                                    Width="120"/>

                <DataGridTextColumn Header="Count"
                                    Binding="{Binding ActiveSubstanceCount}"
                                    Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Padding="12"
                CornerRadius="10"
                Background="White"
                BorderBrush="#D5E0EE"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Selected drug"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBlock Text="{Binding SelectedDrugExplorerResult.DrugName}"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,8,0,0"/>

                <TextBlock Text="{Binding SelectedDrugExplorerResult.Manufacturer, StringFormat=Manufacturer: {0}}"
                           Margin="0,4,0,0"/>

                <TextBlock Text="{Binding SelectedDrugExplorerResult.ActiveSubstances, StringFormat=Active substances: {0}}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>

                <TextBlock Text="{Binding SelectedDrugExplorerResult.Source, StringFormat=Source: {0}}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
