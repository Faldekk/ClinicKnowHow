<UserControl
    x:Class="DrugCompare.Features.PolishRegistry.PolishRegistryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="760"
    d:DesignWidth="1180"
    Background="White">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#EEF2FF"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" >
        <Grid.RowDefinitions>
            <RowDefinition Height="110"  />
            <RowDefinition Height="331*"/>
            <RowDefinition Height="319*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Wyszukiwanie -->
        <Border Height="110" VerticalAlignment="Top" Background="White" Margin="0,5,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="120"/>

                    <ColumnDefinition Width="Auto" MinWidth="118"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Text="Polski Rejestr Produktów Leczniczych"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Margin="10,8,0,6" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Wyszukaj produkt leczniczy"
                    FontWeight="SemiBold"
                    Margin="10,0,0,6" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="80,0,92,10"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Wyszukaj po nazwie produktu, substancji czynnej, podmiocie odpowiedzialnym lub numerze pozwolenia" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="Wyszukaj:"
                    Margin="14,10,865,14"  />
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    Content="Szukaj"
                    Command="{Binding SearchCommand}"
                    Margin="14,0,14,10"  />

                <Button
                    Grid.Row="2"
                    Grid.Column="3"
                    Content="Wyczyść"
                    Command="{Binding ClearCommand}"
                    Margin="14,0,14,10" />
            </Grid>
        </Border>

        <!-- Wyniki -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,10,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock
                        Text="Wyniki"
                        FontSize="18"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Left" />

                    <TextBlock
                        Text="{Binding StatusMessage}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right" />
                </DockPanel>

                <DataGrid
                    Grid.Row="1"
                    ItemsSource="{Binding Results}"
                    SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                    EnableRowVirtualization="True"
                    EnableColumnVirtualization="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Nazwa produktu"
                            Binding="{Binding ProductName}"
                            Width="2*" />

                        <DataGridTextColumn
                            Header="Substancja czynna"
                            Binding="{Binding ActiveSubstanceText}"
                            Width="2*" />

                        <DataGridTextColumn
                            Header="Moc"
                            Binding="{Binding Strength}"
                            Width="120" />

                        <DataGridTextColumn
                            Header="Postać"
                            Binding="{Binding PharmaceuticalForm}"
                            Width="170" />

                        <DataGridTextColumn
                            Header="Typ"
                            Binding="{Binding ProductType}"
                            Width="140" />

                        <DataGridTextColumn
                            Header="Podmiot odpowiedzialny"
                            Binding="{Binding MarketingAuthorizationHolder}"
                            Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Szczegóły -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,1,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="493"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Lewy panel -->
                <Border
                    Grid.Column="0"
                    Background="{StaticResource SoftAccentBrush}"
                    BorderBrush="#C7D2FE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,14,0">

                    <ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>
                            <TextBlock
                                Text="Nazwa produktu"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.ProductName, TargetNullValue=—}"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource AccentBrush}"
                                TextWrapping="Wrap"
                                Margin="0,8,0,14" />

                            <TextBlock
                                Text="Substancja czynna"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.ActiveSubstanceText, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,14" />

                            <TextBlock
                                Text="Moc"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.Strength, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,14" />

                            <TextBlock
                                Text="Postać farmaceutyczna"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.PharmaceuticalForm, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,14" />

                            <TextBlock
                                Text="Typ produktu"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.ProductType, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,14" />

                            <TextBlock
                                Text="Podmiot odpowiedzialny"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.MarketingAuthorizationHolder, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Prawy panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Szczegóły rejestracyjne i dokumenty"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,0,0,10" />

                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <StackPanel Width="779">
                            <TextBlock
                                Text="Dokumenty"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <StackPanel
                                Orientation="Horizontal"
                                Margin="0,8,0,16">

                                <Button
                                    Content="Otwórz ChPL"
                                    Command="{Binding OpenChplCommand}"
                                    MinWidth="120"
                                    Margin="0,0,8,0" />

                                <Button
                                    Content="Otwórz ulotkę"
                                    Command="{Binding OpenLeafletCommand}"
                                    MinWidth="130"
                                    Margin="0,0,0,0" />
                            </StackPanel>

                            <TextBlock
                                Text="Numer pozwolenia"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.AuthorizationNumber, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="Ważność pozwolenia"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.AuthorizationValidity, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="Typ procedury"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.ProcedureType, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="RPL ID"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.RplId, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />


                            <TextBlock
                                Text="Link ChPL"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBox
                                Text="{Binding SelectedResult.ChplUrl, TargetNullValue=Brak linku do ChPL.}"
                                IsReadOnly="True"
                                TextWrapping="Wrap"
                                Height="Auto"
                                MinHeight="36"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="Link do ulotki"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBox
                            Text="{Binding SelectedResult.LeafletUrl, TargetNullValue=Brak linku do ulotki.}"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            Height="Auto"
                            MinHeight="36"
                            Margin="0,6,0,16" />

                            <TextBlock
                                Text="Źródło danych"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.Source, TargetNullValue=RPL}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="Wersja źródła"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.SourceVersion, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,16" />

                            <TextBlock
                                Text="Data importu"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SecondaryTextBrush}" />

                            <TextBlock
                                Text="{Binding SelectedResult.ImportedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=—}"
                                FontSize="15"
                                TextWrapping="Wrap"
                                Margin="0,6,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Pasek statusu -->

    </Grid>
</UserControl>