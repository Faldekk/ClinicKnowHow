<UserControl x:Class="DrugCompare.Features.PolishRegistry.PolishRegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Polish Drug Registry"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Search Polish medicinal products and open ChPL or leaflet documents."
                           Margin="0,4,0,0"
                           Opacity="0.75"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBox Width="360"
                         Height="34"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding PolishDrugRegistryQuery, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Search"
                        Width="110"
                        Height="34"
                        Command="{Binding SearchPolishDrugRegistryCommand}"/>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding PolishDrugRegistryResults}"
                  SelectedItem="{Binding SelectedPolishDrugRegistryItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Product"
                                    Binding="{Binding ProductName}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Substance"
                                    Binding="{Binding ActiveSubstanceText}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Strength"
                                    Binding="{Binding Strength}"
                                    Width="110"/>

                <DataGridTextColumn Header="Form"
                                    Binding="{Binding PharmaceuticalForm}"
                                    Width="180"/>

                <DataGridTextColumn Header="Holder"
                                    Binding="{Binding MarketingAuthorizationHolder}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Auth No."
                                    Binding="{Binding AuthorizationNumber}"
                                    Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Padding="14"
                CornerRadius="10"
                Background="White"
                BorderBrush="#D5E0EE"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Selected product"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.ProductName}"
                               FontSize="19"
                               FontWeight="Bold"
                               Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.ActiveSubstanceText, StringFormat=Substance: {0}}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.Strength, StringFormat=Strength: {0}}"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.PharmaceuticalForm, StringFormat=Form: {0}}"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.MarketingAuthorizationHolder, StringFormat=MAH: {0}}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedPolishDrugRegistryItem.AuthorizationNumber, StringFormat=Authorization: {0}}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Width="150"
                            Margin="16,0,0,0"
                            VerticalAlignment="Top">

                    <Button Content="Open ChPL"
                            Height="36"
                            Margin="0,0,0,8"
                            Command="{Binding OpenSelectedChplCommand}"/>

                    <Button Content="Open leaflet"
                            Height="36"
                            Command="{Binding OpenSelectedLeafletCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
