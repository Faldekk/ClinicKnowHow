<Window x:Class="DrugCompare.DatabaseStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Statistics"
        Width="520"
        Height="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7FA">

    <Grid Margin="18">
        <Border Background="White"
                CornerRadius="12"
                Padding="20"
                BorderBrush="#D6DEE8"
                BorderThickness="1"
                ScrollViewer.VerticalScrollBarVisibility="Visible">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,18">
                    <TextBlock Text="Drug Compare Database"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1B2A38"/>

                    <TextBlock Text="Local PostgreSQL dataset statistics"
                               FontSize="13"
                               Foreground="#607080"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Drugs"
                                       FontWeight="SemiBold"
                                       Foreground="#1B2A38"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DrugsCount, StringFormat=N0}"
                                       FontWeight="Bold"
                                       Foreground="#1E6FB8"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Active substances"
                                       FontWeight="SemiBold"
                                       Foreground="#1B2A38"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveSubstancesCount, StringFormat=N0}"
                                       FontWeight="Bold"
                                       Foreground="#1E6FB8"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Drug-substance relations"
                                       FontWeight="SemiBold"
                                       Foreground="#1B2A38"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DrugActiveSubstancesCount, StringFormat=N0}"
                                       FontWeight="Bold"
                                       Foreground="#1E6FB8"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Background="#FFF7E6"
                            BorderBrush="#F2C879"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Substance interactions"
                                       FontWeight="SemiBold"
                                       Foreground="#1B2A38"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding SubstanceInteractionsCount, StringFormat=N0}"
                                       FontWeight="Bold"
                                       Foreground="#B45309"/>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2"
                            Margin="0,18,0,0">

                    <Button Content="Continue"
                            Width="120"
                            Height="34"
                            HorizontalAlignment="Right"
                            Click="ContinueButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>