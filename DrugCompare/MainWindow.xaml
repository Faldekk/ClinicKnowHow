<Window x:Class="DrugCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drug Compare"
        Width="1250"
        Height="800"
        MinWidth="1100"
        MinHeight="700"
        Background="#F4F7FA">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14"
                BorderBrush="#D6DEE8"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Drug Compare"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1B2A38"/>

                    <TextBlock Text="Local active substance interaction assistant"
                               FontSize="14"
                               Foreground="#607080"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="Aplikacja sprawdza znane interakcje między substancjami aktywnymi w lokalnej bazie. Nie zastępuje decyzji lekarza ani farmaceuty."
                               TextWrapping="Wrap"
                               Foreground="#8A5A00"
                               Margin="0,12,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E8F3FF"
                        BorderBrush="#9CC7F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,6"
                        VerticalAlignment="Top">
                    <TextBlock Text="LOCAL MODE"
                               FontWeight="Bold"
                               Foreground="#135A9E"/>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,10,0"
                    BorderBrush="#D6DEE8"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="1. Drug lookup"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1B2A38"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Drug name"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding DrugNameInput, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,5,0,10"
                             VerticalContentAlignment="Center"/>

                    <Button Content="Find drug"
                            Command="{Binding FindDrugCommand}"
                            Height="36"
                            Margin="0,0,0,16"/>

                    <TextBlock Text="Detected active substances"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <ListBox ItemsSource="{Binding DetectedSubstances}"
                             SelectedItem="{Binding SelectedDetectedSubstance}"
                             Height="170"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Source}"
                                               Foreground="Gray"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Accept selected"
                                Command="{Binding AcceptDetectedSubstanceCommand}"
                                Height="34"
                                Margin="0,0,5,0"/>

                        <Button Grid.Column="1"
                                Content="Accept all"
                                Command="{Binding AcceptAllDetectedSubstancesCommand}"
                                Height="34"
                                Margin="5,0,0,0"/>
                    </Grid>

                    <Separator Margin="0,6,0,14"/>

                    <TextBlock Text="2. Manual active substance"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1B2A38"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Active substance name"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding ManualSubstanceInput, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,5,0,10"
                             VerticalContentAlignment="Center"/>

                    <Button Content="Add active substance"
                            Command="{Binding AddManualSubstanceCommand}"
                            Height="36"/>
                </StackPanel>
            </Border>

            <!-- MIDDLE PANEL -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="10,0,10,0"
                    BorderBrush="#D6DEE8"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="3. Accepted active substances"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1B2A38"
                               Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding AcceptedSubstances}"
                             SelectedItem="{Binding SelectedAcceptedSubstance}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D6DEE8"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>

                                        <TextBlock Text="{Binding DDInterId}"
                                                   Foreground="Gray"
                                                   FontSize="11"
                                                   Margin="0,3,0,0"/>

                                        <TextBlock Text="{Binding Source}"
                                                   Foreground="#607080"
                                                   FontSize="11"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2"
                                Margin="0,12,0,0">
                        <Button Content="Remove selected substance"
                                Command="{Binding RemoveAcceptedSubstanceCommand}"
                                Height="36"
                                Margin="0,0,0,8"/>

                        <Button Content="Check interactions"
                                Command="{Binding CheckInteractionsCommand}"
                                Height="42"
                                FontWeight="Bold"
                                Background="#1E6FB8"
                                Foreground="White"
                                Margin="0,0,0,8"/>

                        <Button Content="Clear case"
                                Command="{Binding ClearCaseCommand}"
                                Height="34"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="10,0,0,0"
                    BorderBrush="#D6DEE8"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="4. Interaction results"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1B2A38"
                               Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding InteractionResults}"
                              SelectedItem="{Binding SelectedInteraction}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="0,0,0,14">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Substance A"
                                                Binding="{Binding SubstanceA}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Substance B"
                                                Binding="{Binding SubstanceB}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Severity"
                                                Binding="{Binding Severity}"
                                                Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="Selected interaction details"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="3"
                            Background="#F8FAFC"
                            BorderBrush="#D6DEE8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">

                        <StackPanel>
                            <TextBlock Text="Severity"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding SelectedInteraction.Severity}"
                                       Margin="0,3,0,12"/>

                            <TextBlock Text="Message"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding SelectedInteraction.Message}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,12"/>

                            <TextBlock Text="Source"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding SelectedInteraction.Source}"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,12"/>

                            <TextBlock Text="Safety note"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Brak znalezionej interakcji nie oznacza, że połączenie jest bezpieczne. Wynik wymaga klinicznej weryfikacji."
                                       TextWrapping="Wrap"
                                       Foreground="#8A5A00"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="2"
                   Margin="0,14,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Text="Processing: local only"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>