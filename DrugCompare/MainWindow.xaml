<Window x:Class="DrugCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drug Compare"
        Width="1400"
        Height="820"
        MinWidth="1150"
        MinHeight="720"
        Background="#F4F7FA">

    <Window.Resources>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="#D6DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1B2A38"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#B9C3CF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#EEF2F6"/>
            <Setter Property="BorderBrush" Value="#B9C3CF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#B9C3CF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#B9C3CF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#EEF2F6"/>
            <Setter Property="Foreground" Value="#1B2A38"/>
            <Setter Property="BorderBrush" Value="#D6DEE8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="16"
                Margin="0,0,0,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Drug Compare"
                               FontSize="26"
                               FontWeight="Bold"/>

                    <TextBlock Text="Local active substance interaction assistant"
                               FontSize="13"
                               Foreground="#607080"
                               Margin="0,3,0,0"/>

                    <TextBlock Text="Aplikacja sprawdza znane interakcje między substancjami aktywnymi w lokalnej bazie. Nie zastępuje decyzji lekarza ani farmaceuty."
                               FontSize="12"
                               Foreground="#8A5A00"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E8F3FF"
                        BorderBrush="#9CC7F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,6"
                        VerticalAlignment="Top"
                        Margin="16,0,0,0">
                    <TextBlock Text="LOCAL MODE"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#135A9E"/>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="1.55*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="0,0,8,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="1. Drug lookup"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Drug name"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBox Text="{Binding DrugNameInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>

                        <Button Content="Find drug"
                                Command="{Binding FindDrugCommand}"
                                Margin="0,0,0,12"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Detected active substances"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding DetectedSubstances}"
                                 SelectedItem="{Binding SelectedDetectedSubstance}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6"
                                            Margin="0,0,0,4"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding DDInterId}"
                                                       Foreground="#607080"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding Source}"
                                                       Foreground="#607080"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="0,10,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Accept selected"
                                Command="{Binding AcceptDetectedSubstanceCommand}"
                                Margin="0,0,5,0"/>

                        <Button Grid.Column="1"
                                Content="Accept all"
                                Command="{Binding AcceptAllDetectedSubstancesCommand}"
                                Margin="5,0,0,0"/>
                    </Grid>

                    <Separator Grid.Row="4"
                               Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="5">
                        <TextBlock Text="2. Manual active substance"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Active substance name"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBox Text="{Binding ManualSubstanceInput, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>

                        <Button Content="Add active substance"
                                Command="{Binding AddManualSubstanceCommand}"/>

                        <TextBlock Text="Tip: for DDInter tests, paste the exact active substance name from the database."
                                   FontSize="11"
                                   Foreground="#607080"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MIDDLE PANEL -->
            <Border Grid.Column="1"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="8,0,8,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="3. Accepted active substances"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding AcceptedSubstances}"
                             SelectedItem="{Binding SelectedAcceptedSubstance}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D6DEE8"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8"
                                        Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,3,0,0">
                                            <TextBlock Text="DB ID: "
                                                       Foreground="#607080"
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding DatabaseId}"
                                                       Foreground="#607080"
                                                       FontSize="10"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,2,0,0">
                                            <TextBlock Text="DDInter: "
                                                       Foreground="#607080"
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding DDInterId}"
                                                       Foreground="#607080"
                                                       FontSize="10"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Source}"
                                                   Foreground="#607080"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2"
                                Margin="0,10,0,0">
                        <Button Content="Remove selected substance"
                                Command="{Binding RemoveAcceptedSubstanceCommand}"
                                Margin="0,0,0,7"/>

                        <Button Content="Check interactions"
                                Command="{Binding CheckInteractionsCommand}"
                                Height="40"
                                FontWeight="Bold"
                                Background="#1E6FB8"
                                Foreground="White"
                                BorderBrush="#155A94"
                                Margin="0,0,0,7"/>

                        <Button Content="Clear case"
                                Command="{Binding ClearCaseCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="8,0,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2.2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="4. Interaction results"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding InteractionResults}"
                              SelectedItem="{Binding SelectedInteraction}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="0,0,0,12"
                              MinColumnWidth="90">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Substance A"
                                                Binding="{Binding SubstanceA}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Substance B"
                                                Binding="{Binding SubstanceB}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Severity"
                                                Binding="{Binding Severity}"
                                                Width="95"/>

                            <DataGridTextColumn Header="Message"
                                                Binding="{Binding Message}"
                                                Width="260"/>

                            <DataGridTextColumn Header="Source"
                                                Binding="{Binding Source}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="Selected interaction details"
                               FontSize="15"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <Border Grid.Row="3"
                            Background="#F8FAFC"
                            BorderBrush="#D6DEE8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Severity"
                                           FontSize="12"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding SelectedInteraction.Severity}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Message"
                                           FontSize="12"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding SelectedInteraction.Message}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Source"
                                           FontSize="12"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding SelectedInteraction.Source}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Text="Safety note: Brak znalezionej interakcji nie oznacza, że połączenie jest bezpieczne. Wynik wymaga klinicznej weryfikacji."
                                       FontSize="11"
                                       Foreground="#8A5A00"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="2"
                   Margin="0,12,0,0"
                   Height="28">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Text="Processing: local only"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>