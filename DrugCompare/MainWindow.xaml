<Window x:Class="DrugCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DrugCompare.Views"
        Title="Drug Compare"
        Width="1400"
        Height="760"
        MinWidth="1180"
        MinHeight="640"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F4F7FB">
        <TabControl Margin="8"
                    BorderThickness="0"
                    Background="Transparent">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="14,7"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Interaction Check">
                <views:InteractionCheckView/>
            </TabItem>

            <TabItem Header="History">
                <views:HistoryView/>
            </TabItem>

            <TabItem Header="Database Status">
                <views:DatabaseStatusView/>
            </TabItem>

            <TabItem Header="Data Management">
                <views:DataManagementView/>
            </TabItem>

            <TabItem Header="Audit Log">
                <views:AuditLogView/>
            </TabItem>

            <TabItem Header="Settings">
                <views:SettingsView/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>